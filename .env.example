# ===== قاعدة البيانات (Supabase / PostgreSQL) =====
# من Supabase: Project Settings > Database > Connection string
# DATABASE_URL = الرابط المُجمّع (Connection Pooling / Transaction، منفذ 6543) مع pgbouncer=true
# DIRECT_URL   = الرابط المباشر (Direct، منفذ 5432)
DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-region.pooler.supabase.com:5432/postgres"

# ===== الدخول =====
ADMIN_PASSWORD="ضع_كلمة_مرور_قوية"
SESSION_SECRET="ضع_نصًا_عشوائيًا_طويلًا_جدًا"

# ===== رأس المال =====
INITIAL_CAPITAL="200000"

# ===== Telegram (اختياري) =====
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ===== حماية مسار الإشعارات المجدولة =====
CRON_SECRET="ضع_سرًا_عشوائيًا"

# ===== واتساب الشركة =====
COMPANY_WHATSAPP="201120442206"
